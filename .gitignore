# ── Общий .gitignore корня chatium.chatium-sync ──
# Охватывает оба воркспейса (s.chtm.khudoley.pro, p.chtm.khudoley.pro) и корневой тулинг.

# Зависимости
**/node_modules/

# IDE
**/.cursor/
**/.vscode/

# CodeGraph — локальный индекс и состояние демона
/.codegraph/

# Семантический поиск по докам (obsidian-hybrid-search MCP) — локальный индекс,
# регенерируется per-machine как .codegraph. Лежит внутри vault (inner/docs),
# т.к. сервер кладёт БД рядом с индексируемыми файлами (путь БД не настраивается).
inner/docs/.obsidian-hybrid-search.db
inner/docs/.obsidian-hybrid-search.db-wal
inner/docs/.obsidian-hybrid-search.db-shm

# Состояние sync-агента (регенерируется: tree.json, статусы, rate-limit)
/configs/

# Артефакты браузерных сессий (Playwright MCP) и скриншоты страниц оплаты
/.playwright-mcp/
**/payment-*.png
**/pw-payment-styles-*.json

# Внутренние LLM-логи
**/docs/LLM/

# Временные конфиги строгой проверки типов (scripts/check-types.mjs)
**/.tsconfig.strict-check.*.tmp.json

# Лог трекинга лимитов за прогон (scripts/usage-limits.mjs)
**/scripts/.usage-log/

# Runtime/debug логи
*.log
